MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
PORT=3000
JSON_BODY_LIMIT=10mb

# AI provider: gemini
AI_PROVIDER=gemini
AI_MAX_CV_CHARS=60000
AI_MAX_JOB_DESCRIPTION_CHARS=1800

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# JSearch / RapidAPI
JSEARCH_API_KEY=your_rapidapi_jsearch_key
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# n8n orchestration
# This project uses n8n test webhook URLs. In n8n, click "Listen for test event"
# before triggering an upload; test webhooks are not registered otherwise.
USE_N8N_RESUME_WORKFLOW=true
N8N_BASE_URL=http://localhost:5678
BACKEND_URL=https://acronym-clerk-unclog.ngrok-free.dev
N8N_SHARED_SECRET=change_me_to_a_long_random_secret
N8N_RESUME_UPLOAD_WEBHOOK=/webhook-test/recruitment/resume-upload
N8N_MARKET_ANALYSIS_WEBHOOK=/webhook-test/recruitment/market-analysis
N8N_JOB_MATCHING_WEBHOOK=/webhook-test/recruitment/job-matching
N8N_EMAIL_DISCOVERY_WEBHOOK=/webhook-test/recruitment/email-discovery
N8N_APPLICATION_GENERATION_WEBHOOK=/webhook-test/recruitment/application-generation
N8N_EMAIL_SENDING_WEBHOOK=/webhook-test/recruitment/email-sending
N8N_GMAIL_MONITORING_WEBHOOK=/webhook-test/recruitment/gmail-monitoring
N8N_NOTIFICATION_WEBHOOK=/webhook-test/recruitment/notification
N8N_CHAT_WEBHOOK=/webhook-test/recruitment/chat

# Authorized API providers only. Current job search provider: JSearch.
HUNTER_API_KEY=your_hunter_api_key
APOLLO_API_KEY=your_apollo_api_key
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://acronym-clerk-unclog.ngrok-free.dev/api/v1/integrations/gmail/callback
FRONTEND_URL=http://localhost:5173
TOKEN_ENCRYPTION_SECRET=change_me_to_a_long_random_token_secret
